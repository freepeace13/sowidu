{
  "name": "sowidu-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "build": "eas build --profile production --platform android --non-interactive",
    "build:staging": "eas build --profile staging --platform android --non-interactive",
    "prebuild": "expo prebuild --clean --platform android",
    "update:production": "EXPO_PUBLIC_API_URL=https://sowidu.de/api/v1 eas update -p android --auto",
    "update:staging": "EXPO_PUBLIC_API_URL=https://staging.sowidu.de/api/v1 eas update -p android --auto",
    "eject": "expo eject",
    "ts:check": "tsc",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "lint": "eslint ./src/ --fix --ext .ts,.tsx",
    "fix-code-style": "npm run format && npm run lint",
    "android": "expo run:android --device",
    "ios": "expo run:ios --device",
    "test": "jest"
  },
  "dependencies": {
    "@config-plugins/react-native-pdf": "^8.0.0",
    "@expo-google-fonts/roboto": "^0.2.3",
    "@expo/config-plugins": "~8.0.0",
    "@gorhom/bottom-sheet": "^4",
    "@openspacelabs/react-native-zoomable-view": "^2.1.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.0.1",
    "@react-native-community/slider": "4.5.2",
    "@react-navigation/bottom-tabs": "^6.4.0",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/elements": "^1.3.16",
    "@react-navigation/native": "^6.0.11",
    "@react-navigation/native-stack": "^6.7.0",
    "@react-navigation/stack": "^6.3.14",
    "@reduxjs/toolkit": "^1.9.7",
    "@sentry/react-native": "~5.24.3",
    "@types/lodash": "^4.17.10",
    "deepmerge": "^4.3.1",
    "expo": "^51.0.39",
    "expo-application": "~5.9.1",
    "expo-av": "~14.0.7",
    "expo-camera": "~15.0.16",
    "expo-constants": "~16.0.2",
    "expo-crypto": "~13.0.2",
    "expo-dev-client": "~4.0.29",
    "expo-device": "~6.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-image": "~1.13.0",
    "expo-image-manipulator": "~12.0.5",
    "expo-image-picker": "~15.1.0",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-localization": "~15.0.3",
    "expo-media-library": "~16.0.5",
    "expo-navigation-bar": "~3.0.7",
    "expo-network": "~6.0.1",
    "expo-screen-orientation": "~7.0.5",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "expo-updates": "~0.25.28",
    "i18n-js": "^4.3.0",
    "lodash": "^4.17.21",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.52.0",
    "react-native": "0.74.5",
    "react-native-blob-util": "^0.19.9",
    "react-native-circular-progress": "^1.3.9",
    "react-native-drawer-layout": "^3.2.2",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-image-crop-tools": "^1.6.4",
    "react-native-keyboard-controller": "^1.14.4",
    "react-native-pager-view": "6.3.0",
    "react-native-paper": "^5.12.3",
    "react-native-pdf": "^6.7.5",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-vector-icons": "^10.0.2",
    "react-native-webview": "13.8.6",
    "react-redux": "^8.1.3",
    "redux-persist": "^6.0.0",
    "rn-emoji-keyboard": "^1.7.0",
    "stable-hash": "^0.0.2",
    "tinycolor2": "^1.4.2",
    "validatorjs": "^3.22.1",
    "@config-plugins/react-native-blob-util": "^8.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.19.3",
    "@babel/plugin-proposal-async-generator-functions": "^7.19.1",
    "@faker-js/faker": "^7.6.0",
    "@types/jest": "^29.5.12",
    "axios": "^0.27.2",
    "babel-loader": "^8.2.5",
    "babel-plugin-module-resolver": "^4.1.0",
    "babel-plugin-wildcard": "^7.0.0",
    "eslint": "^8.21.0",
    "eslint-config-expo": "^7.1.2",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-universe": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.4",
    "lint-staged": "^13.0.3",
    "prettier": "^2.7.1",
    "react-devtools": "^4.26.1",
    "react-native-svg-transformer": "^1.3.0",
    "reactotron-react-native": "^5.0.3",
    "reactotron-redux": "^3.1.3",
    "redux-logger": "^3.0.6",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.1",
    "typescript": "~5.3.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "npm run fix-code-style"
  },
  "private": true,
  "workspaces": [
    "src/**",
    "hexagonal/**"
  ]
}
