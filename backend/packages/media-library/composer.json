{
    "name": "sowidu/media-library",
    "description": "Media library package for Laravel",
    "version": "1.x-dev",
    "require": {
        "php": "^7.3|^8.0",
        "illuminate/support": "^9.0",
        "illuminate/database": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Packages\\MediaLibrary\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Packages\\MediaLibrary\\MediaLibraryServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
