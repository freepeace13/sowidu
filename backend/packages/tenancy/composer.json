{
    "name": "sowidu/tenancy",
    "description": "Team/tenancy context management package for Laravel applications",
    "version": "1.x-dev",
    "require": {
        "php": "^7.3|^8.0",
        "illuminate/support": "^9.0",
        "illuminate/database": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Packages\\Tenancy\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Packages\\Tenancy\\TenancyServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
