{
    "name": "sowidu/translation",
    "description": "Database driven translation loader and manager",
    "version": "1.x-dev",
    "require": {
        "php": "^7.3|^8.0",
        "illuminate/support": "^9.0",
        "illuminate/contracts": "^9.0",
        "illuminate/translation": "^9.0",
        "illuminate/database": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Packages\\Translation\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Packages\\Translation\\TranslationServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
