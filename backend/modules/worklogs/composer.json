{
    "name": "sowidu/worklogs",
    "description": "WorkLogs is a simple work logging system for Laravel.",
    "version": "1.x-dev",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Modules\\WorkLogs\\": "src/",
            "Modules\\WorkLogs\\Tests\\": "tests/",
            "Modules\\WorkLogs\\Database\\": "database/",
            "Modules\\WorkLogs\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Modules\\WorkLogs\\Providers\\WorkLogServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}