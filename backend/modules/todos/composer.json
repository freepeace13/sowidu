{
    "name": "sowidu/todos",
    "description": "Sowidu Todo is a simple task management system for Laravel.",
    "version": "1.x-dev",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Todos\\": "src/",
            "Modules\\Todos\\Tests\\": "tests/",
            "Modules\\Todos\\Database\\": "database/",
            "Modules\\Todos\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Todos\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Modules\\Todos\\Providers\\TodoServiceProvider",
                "Modules\\Todos\\Providers\\TodoAuthServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}