{
    "name": "sowidu/shared",
    "description": "Common views and components for Sowidu.",
    "version": "1.x-dev",
    "authors": [
        {
            "name": "Kin Basco",
            "email": "freepeace13@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "spatie/laravel-data": "^3.12.0"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Shared\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Shared\\SharedServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
