{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.0",
        "alchemy/zippy": "1.x-dev",
        "archtechx/enums": "^0.3.2",
        "awt/apilogger": "@dev",
        "barryvdh/laravel-dompdf": "^3.1",
        "beyondcode/laravel-websockets": "^1.14",
        "bugsnag/bugsnag-laravel": "*",
        "cesargb/laravel-magiclink": "^2.8",
        "doctrine/dbal": "^2.7",
        "gladcodes/keygen": "^1.1",
        "guzzlehttp/guzzle": "^7.2",
        "horstoeko/zugferd-laravel": "^1.0",
        "horstoeko/zugferdvisualizer": "^1.0",
        "inertiajs/inertia-laravel": "^0.6.4",
        "laravel/framework": "^9.19",
        "laravel/helpers": "^1.4",
        "laravel/horizon": "^5.9.7",
        "laravel/passport": "^10.4.1",
        "laravel/sanctum": "^3.0",
        "laravel/telescope": "^5.2",
        "laravel/tinker": "^2.7",
        "laravel/vonage-notification-channel": "^3.0",
        "maestroerror/heif-converter": "^0.2.0",
        "maestroerror/php-heic-to-jpg": "^1.0",
        "moneyphp/money": "^4.7",
        "mpdf/mpdf": "^8.1",
        "musonza/chat": "^6.0",
        "nyholm/psr7": "^1.3",
        "opcodesio/log-viewer": "^3.5",
        "opis/closure": "^3.6",
        "php-ffmpeg/php-ffmpeg": "^1.3",
        "pion/laravel-chunk-upload": "^1.2",
        "predis/predis": "^1.1",
        "pusher/pusher-php-server": "^7.2",
        "sowidu/active-status": "1.x-dev",
        "sowidu/addressable": "1.x-dev",
        "sowidu/avatarable": "1.x-dev",
        "sowidu/catalog": "1.x-dev",
        "sowidu/chatly": "1.x-dev",
        "sowidu/contacts": "1.x-dev",
        "sowidu/countries": "1.x-dev",
        "sowidu/data": "1.x-dev",
        "sowidu/delivery-ticket": "1.x-dev",
        "sowidu/invoicify": "1.x-dev",
        "sowidu/laravel-shared-data": "1.x-dev",
        "sowidu/media-library": "1.x-dev",
        "sowidu/offer": "1.x-dev",
        "sowidu/restapi": "1.x-dev",
        "sowidu/tenancy": "1.x-dev",
        "sowidu/todos": "^1.0@dev",
        "sowidu/translation": "1.x-dev",
        "sowidu/urn": "1.x-dev",
        "sowidu/worklogs": "1.x-dev",
        "spatie/browsershot": "^3.61",
        "spatie/image": "^1.10",
        "spatie/image-optimizer": "^1.4",
        "spatie/laravel-activitylog": "^4.6",
        "spatie/laravel-model-states": "^2.4",
        "spatie/laravel-permission": "^5.6",
        "spatie/laravel-searchable": "^1.11",
        "spatie/laravel-sluggable": "^3.4",
        "spatie/laravel-translatable": "^6.0",
        "spatie/pdf-to-image": "^2.1",
        "spatie/temporary-directory": "^2.1",
        "staudenmeir/belongs-to-through": "^2.5",
        "stechstudio/laravel-zipstream": "^4.14",
        "symfony/psr-http-message-bridge": "^2.0",
        "taylornetwork/laravel-username-generator": "^2.3",
        "tightenco/ziggy": "^1.2",
        "tucker-eric/eloquentfilter": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^2.12",
        "fakerphp/faker": "^1.9.1",
        "filp/whoops": "^2.0",
        "fitztrev/query-tracer": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.13",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.16",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^1.0",
        "spatie/laravel-web-tinker": "^1.7",
        "spatie/phpunit-snapshot-assertions": "^4.2.12"
    },
    "autoload": {
        "classmap": [
            "packages"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/Alias.php",
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "Spatie\\Permission\\PermissionServiceProvider",
                "laravel/telescope"
            ]
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php -r \"if (file_exists('bootstrap/cache/packages.php')) unlink('bootstrap/cache/packages.php');\"",
            "@php -r \"if (file_exists('bootstrap/cache/services.php')) unlink('bootstrap/cache/services.php');\"",
            "@php -r \"if (file_exists('bootstrap/cache/config.php')) unlink('bootstrap/cache/config.php');\"",
            "@php artisan package:discover",
            "@php artisan clear-compiled"
        ],
        "test": [
            "./vendor/bin/phpunit"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "prefer-lowest": false,
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "./modules/*",
            "options": {
                "symlink": true
            }
        }
    ]
}
